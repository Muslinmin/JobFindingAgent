# Copy this file to .env and fill in the values before running the app.
#
#   cp .env.example .env
#
# .env is gitignored — never commit real keys.

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./jobs.db

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Agent model ───────────────────────────────────────────────────────────────
# The model prefix tells LiteLLM which provider to route to.
# Only fill in the API key for the provider you choose.
#
#   Anthropic  →  MODEL=claude-sonnet-4-5
#   OpenAI     →  MODEL=gpt-4o
#   Gemini     →  MODEL=gemini/gemini-2.0-flash-lite
MODEL=gemini/gemini-2.0-flash-lite

# ── API keys ──────────────────────────────────────────────────────────────────
# Fill in only the key for the provider that matches MODEL above.
# Unused keys can be left blank.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Scraper ───────────────────────────────────────────────────────────────────
# Sign up at https://tavily.com and copy your key from the dashboard.
TAVILY_API_KEY=tvly-...

# Default search query used by the scheduler and agent search_jobs tool.
SCRAPE_QUERY=software engineer Singapore

# Maximum results returned per Tavily call (keeps quota usage predictable).
SCRAPE_MAX_RESULTS=10

# ── Cloud deployment notes ────────────────────────────────────────────────────
# On cloud platforms (Railway, Render, Fly.io, AWS etc.) do NOT upload this file.
# Instead, set each variable through the platform's environment/secrets dashboard:
#
#   Railway   → Project → Variables
#   Render    → Service → Environment
#   Fly.io    → fly secrets set GEMINI_API_KEY=sk-...
#   AWS ECS   → Task Definition → Environment variables
#   Docker    → docker run -e GEMINI_API_KEY=sk-... or use --env-file .env locally
